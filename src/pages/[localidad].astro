---
import propiedades from "../data/propiedades.json";
import localidades from "../data/localidades.json";

export function getStaticPaths() {
  return localidades.map((loc) => ({
    params: { localidad: loc.slug }
  }));
}

const { localidad } = Astro.params;

if (!localidad) {
  throw new Error("Localidad no definida");
}

const propiedadesFiltradas = propiedades.filter(
  (prop) => prop.localidad === localidad
);

const tipos = [
  { key: "casa", label: "CASAS" },
  { key: "departamento", label: "DEPARTAMENTOS" },
  { key: "local", label: "LOCALES - OFICINAS" },
  { key: "lote", label: "LOTES" },
  { key: "campo", label: "CAMPOS" }
];

const agrupadas = tipos.map((tipo) => ({
  ...tipo,
  items: propiedadesFiltradas.filter((p) => p.tipo === tipo.key)
}));

const imagenesTipo = {
  casa: "/icons/casa.png",
  departamento: "/icons/depto.png",
  local: "/icons/local.png",
  lote: "/icons/lote.png",
  campo: "/icons/campo.png"
};
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>{localidad.toUpperCase()} | Catálogo</title>
  </head>

  <body>
    <main class="catalogo">

      <h1>{localidad.toUpperCase()}</h1>

      {agrupadas.map((grupo) => (
        grupo.items.length > 0 && (
          <section class="bloque">
            <h2>{grupo.label}</h2>

            <div class="grid">
  {grupo.items.map((prop) => (
    <a href={`/propiedad/${prop.id}`} class="card">
      <img
        src={prop.imagenes[0] || imagenesTipo[prop.tipo as keyof typeof imagenesTipo]}
        alt={prop.titulo}
      />

      <div class="info">
        <h3>{prop.titulo}</h3>
        <p>{prop.precio}</p>
      </div>
    </a>
  ))}
</div>
          </section>
        )
      ))}

      {propiedadesFiltradas.length === 0 && (
        <p class="empty">
          No hay propiedades disponibles en esta zona.
        </p>
      )}

    </main>
  </body>
</html>

<style>
  body {
    margin: 0;
    font-family: "Poppins", sans-serif;
    background: #f1f5f9;
  }

  .catalogo {
    max-width: 1200px;
    margin: auto;
    padding: 3rem 1.5rem;
  }

  h1 {
    text-align: center;
    margin-bottom: 3rem;
    color: #0f172a;
    letter-spacing: 0.1em;
  }

  .bloque {
    margin-bottom: 3rem;
  }

  .bloque h2 {
    margin-bottom: 1.2rem;
    color: #1e3a8a;
    font-size: 1.2rem;
    letter-spacing: 0.08em;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.2rem;
  }

  .card {
    background: white;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 6px 18px rgba(0,0,0,0.08);
    transition: transform 0.2s ease;
  }

  .card:hover {
    transform: translateY(-5px);
  }

  .card img {
    width: 100%;
    height: 140px;
    object-fit: cover;
  }

  .info {
    padding: 0.8rem;
  }

  .info h3 {
    font-size: 0.9rem;
    margin: 0 0 0.3rem;
    color: #0f172a;
  }

  .info p {
    margin: 0;
    font-size: 0.8rem;
    color: #475569;
  }

  .empty {
    text-align: center;
    margin-top: 2rem;
    color: #64748b;
  }
</style>