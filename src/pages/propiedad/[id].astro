---
import propiedades from "../../data/propiedades.json";

export function getStaticPaths() {
  return propiedades.map((prop) => ({
    params: { id: prop.id.toString() }
  }));
}

const { id } = Astro.params;

const propiedad = propiedades.find(
  (p) => p.id.toString() === id
);

if (!propiedad) {
  throw new Error("Propiedad no encontrada");
}
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>{propiedad.titulo}</title>
  </head>

  <body>
    <main class="propiedad">

      <div class="container">

        <div class="image">
          <img src={propiedad.imagen} alt={propiedad.titulo} />
        </div>

        <div class="info">
          <h1>{propiedad.titulo}</h1>

          <p class="precio">{propiedad.precio}</p>

          <p class="meta">
            {propiedad.localidad.toUpperCase()} · {propiedad.tipo.toUpperCase()}
          </p>

          <p class="descripcion">
            {propiedad.descripcion}
          </p>

          <!-- Contacto -->
          <div class="contacto">
            <h3>Contactar vendedor</h3>

            <a
              href={`https://wa.me/${propiedad.vendedor.telefono}`}
              target="_blank"
              class="btn whatsapp"
            >
              WhatsApp
            </a>

            <a
              href={`mailto:${propiedad.vendedor.email}`}
              class="btn email"
            >
              Enviar Email
            </a>
          </div>
        </div>

      </div>

    </main>
  </body>
</html>

<style>
  body {
    margin: 0;
    font-family: "Poppins", sans-serif;
    background: #f1f5f9;
  }

  .propiedad {
    padding: 3rem 1.5rem;
  }

  .container {
    max-width: 1100px;
    margin: auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }

  .image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .info {
    padding: 2rem;
  }

  h1 {
    margin: 0 0 1rem;
    color: #0f172a;
  }

  .precio {
    font-size: 1.4rem;
    font-weight: 600;
    color: #1e3a8a;
    margin-bottom: 0.5rem;
  }

  .meta {
    font-size: 0.85rem;
    color: #64748b;
    margin-bottom: 1rem;
  }

  .descripcion {
    font-size: 0.95rem;
    line-height: 1.6;
    color: #334155;
    margin-bottom: 2rem;
  }

  .contacto h3 {
    margin-bottom: 1rem;
  }

  .btn {
    display: inline-block;
    margin-right: 0.5rem;
    padding: 0.7rem 1.2rem;
    border-radius: 8px;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
    color: white;
    transition: 0.2s;
  }

  .whatsapp {
    background: #22c55e;
  }

  .whatsapp:hover {
    background: #16a34a;
  }

  .email {
    background: #2563eb;
  }

  .email:hover {
    background: #1d4ed8;
  }

  @media (max-width: 768px) {
    .container {
      grid-template-columns: 1fr;
    }

    .image img {
      height: 250px;
    }
  }
</style>