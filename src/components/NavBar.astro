<section class="navbar">
  <div class="navbar-container">
    <div class="navbar-logo">
      <img src="/Logo.png" alt="Logo" />
    </div>
    <div class="navbar-links">
      <a href="/">Inicio</a>
      <a href="/">Catalogo</a>
      <a href="/">Tasaciones</a>
      <a href="/">Contacto</a>
    </div>
  </div>
</section>

<style>
  .navbar {
    width: 100%;
    position: sticky;
    top: 0;
    z-index: 1000;
    background: white;
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .navbar-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .navbar-logo img {
    height: 42px;
    width: auto;
    cursor: pointer;
    transition: transform 0.3s ease;
  }

  .navbar-logo img:hover {
    transform: scale(1.05);
  }

  .navbar-links {
    display: flex;
    gap: 30px;
  }

  .navbar-links a {
    position: relative;
    text-decoration: none;
    color: #0c1324d9;
    font-family: "Poppins", sans-serif;
    font-size: 15px;
    letter-spacing: 0.5px;
    transition: color 0.3s ease;
  }

  .navbar-links a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -6px;
    width: 0%;
    height: 2px;
    background: linear-gradient(90deg, #3b82f6, #60a5fa);
    transition: width 0.3s ease;
  }

  .navbar-links a:hover {
    color: #05080fd9;
  }

  .navbar-links a:hover::after {
    width: 100%;
  }

  @media (max-width: 768px) {
    .navbar-container {
      padding: 12px 16px;
    }

    .navbar-links {
      gap: 18px;
    }

    .navbar-links a {
      font-size: 14px;
    }

    .navbar-logo img {
      height: 36px;
    }
  }
</style>
