---
const year = new Date().getFullYear();

const waNumber = "542345653457";
const waMessage = encodeURIComponent(
  "Hola, me contacto desde la web de Inmobiliaria Arnaiz. Me gustaría recibir más información."
);
const waHref = `https://wa.me/${waNumber}?text=${waMessage}`;
---

<footer class="footer">
  <div class="footer-wrap">
    <div class="footer-band">
      <a href="/" class="footer-brand" aria-label="Inicio — Inmobiliaria Arnaiz">
        <img src="/Logo.png" alt="" width="140" height="42" loading="lazy" />
      </a>

      <a
        href={waHref}
        class="footer-wa"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="footer-wa-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            />
          </svg>
        </span>
        <span class="footer-wa-copy">
          <span class="footer-kicker">WhatsApp</span>
          <span class="footer-wa-line">Enviar mensaje</span>
          <span class="footer-wa-hint">Te respondemos a la brevedad</span>
        </span>
      </a>

      <div class="footer-cell">
        <span class="footer-kicker">Dirección</span>
        <p class="footer-text">Av. Belgrano 2498, Saladillo, Bs. As.</p>
      </div>

      <div class="footer-cell">
        <span class="footer-kicker">Horarios</span>
        <p class="footer-text">Lun. a vie. 8:30 — 19:30 hs.</p>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <p class="footer-copy">© {year} Inmobiliaria Arnaiz</p>
  </div>
</footer>

<style>
  .footer {
    font-family: "Poppins", sans-serif;
    color: #1e293b;
    background: linear-gradient(165deg, #f8fafc 0%, #eef2f7 45%, #e8edf4 100%);
    border-top: 1px solid rgba(15, 23, 42, 0.06);
  }

  .footer-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 36px 24px 26px;
  }

  .footer-band {
    display: grid;
    grid-template-columns: minmax(100px, auto) minmax(200px, 1.2fr) minmax(180px, 1fr) minmax(160px, 0.95fr);
    align-items: stretch;
    gap: 0;
    border-radius: 18px;
    overflow: hidden;
    background: #fff;
    border: 1px solid rgba(148, 163, 184, 0.22);
    box-shadow:
      0 1px 2px rgba(15, 23, 42, 0.04),
      0 12px 40px -18px rgba(15, 23, 42, 0.12);
  }

  .footer-brand {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 22px 26px;
    background: linear-gradient(180deg, #fafbfc 0%, #f4f6f9 100%);
    border-right: 1px solid rgba(226, 232, 240, 0.9);
    line-height: 0;
    transition: background 0.2s ease;
  }

  .footer-brand:hover {
    background: linear-gradient(180deg, #f1f5f9 0%, #e8edf3 100%);
  }

  .footer-brand img {
    height: 44px;
    width: auto;
    display: block;
  }

  .footer-wa {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 20px 22px;
    text-decoration: none;
    color: inherit;
    background: linear-gradient(135deg, rgba(37, 211, 102, 0.1) 0%, rgba(18, 140, 126, 0.06) 100%);
    border-right: 1px solid rgba(226, 232, 240, 0.85);
    transition:
      background 0.22s ease,
      box-shadow 0.22s ease;
  }

  .footer-wa:hover {
    background: linear-gradient(135deg, rgba(37, 211, 102, 0.16) 0%, rgba(18, 140, 126, 0.1) 100%);
    box-shadow: inset 0 0 0 1px rgba(37, 211, 102, 0.2);
  }

  .footer-wa:focus-visible {
    outline: 2px solid #25d366;
    outline-offset: -2px;
  }

  .footer-wa-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    border-radius: 14px;
    background: #fff;
    color: #25d366;
    box-shadow: 0 2px 8px rgba(37, 211, 102, 0.18);
  }

  .footer-wa-copy {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .footer-kicker {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #64748b;
  }

  .footer-wa .footer-kicker {
    color: #15803d;
  }

  .footer-wa-line {
    font-size: 15px;
    font-weight: 600;
    color: #0f172a;
    letter-spacing: -0.01em;
  }

  .footer-wa-hint {
    font-size: 12px;
    color: #64748b;
    line-height: 1.35;
    margin-top: 2px;
  }

  .footer-cell {
    padding: 20px 22px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    justify-content: center;
    background: #fff;
  }

  .footer-cell + .footer-cell {
    border-left: 1px solid rgba(241, 245, 249, 0.95);
  }

  .footer-text {
    margin: 0;
    font-size: 14px;
    line-height: 1.5;
    font-weight: 500;
    color: #334155;
  }

  .footer-bottom {
    border-top: 1px solid rgba(226, 232, 240, 0.75);
    background: rgba(255, 255, 255, 0.45);
  }

  .footer-copy {
    margin: 0;
    max-width: 1200px;
    margin-inline: auto;
    padding: 16px 24px 22px;
    text-align: center;
    font-size: 12px;
    letter-spacing: 0.02em;
    color: #94a3b8;
  }

  @media (max-width: 960px) {
    .footer-band {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
      border-right: none;
      border-bottom: 1px solid rgba(226, 232, 240, 0.9);
      padding: 20px;
    }

    .footer-brand img {
      height: 40px;
    }

    .footer-wa {
      grid-column: 1 / -1;
      border-right: none;
      border-bottom: 1px solid rgba(226, 232, 240, 0.85);
    }

    .footer-band > .footer-cell:first-of-type {
      border-right: 1px solid rgba(241, 245, 249, 0.95);
    }

    .footer-band > .footer-cell + .footer-cell {
      border-left: none;
      border-top: none;
    }
  }

  @media (max-width: 560px) {
    .footer-wrap {
      padding: 28px 16px 20px;
    }

    .footer-band {
      grid-template-columns: 1fr;
      border-radius: 14px;
    }

    .footer-wa {
      border-bottom: 1px solid rgba(226, 232, 240, 0.85);
    }

    .footer-band > .footer-cell:first-of-type {
      border-right: none;
    }

    .footer-band > .footer-cell + .footer-cell {
      border-left: none;
      border-top: 1px solid rgba(241, 245, 249, 0.95);
    }
  }
</style>
